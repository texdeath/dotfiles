# Theme
theme = Blazer

# Font
font-size = 14

# Window
window-padding-x = 8
window-padding-y = 4
window-decoration = auto

# Shell
shell-integration = zsh
command = /bin/zsh -lc 'exec tmux new-session -A -s main'

# Misc
copy-on-select = clipboard
mouse-hide-while-typing = true
macos-option-as-alt = true
