#### 基本設定 ########################################################

export LANG=ja_JP.UTF-8
export LC_CTYPE=ja_JP.UTF-8

# 履歴設定
HISTFILE=$HOME/.zsh_history
HISTSIZE=100000
SAVEHIST=100000
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_REDUCE_BLANKS
setopt SHARE_HISTORY

bindkey -e  # Emacs キーバインド
setopt AUTO_CD AUTO_PUSHD PUSHD_IGNORE_DUPS CORRECT NO_BEEP

#### モジュール読み込み ##############################################

for f in \
  "$HOME/.zsh/tools.zsh" \
  "$HOME/.zsh/plugins.zsh" \
  "$HOME/.zsh/completions.zsh" \
  "$HOME/.zsh/aliases.zsh" \
  "$HOME/.zsh/functions.zsh" \
  "$HOME/.zsh/orchestrate.zsh" \
  "$HOME/.zsh/prompt.zsh"
do
  [[ -f "$f" ]] && source "$f"
done

#### Claude Code ####################################################

# Claude Code: デフォルトのeffort levelをmaxに設定 (2026-04-09)
# settings.jsonではmaxが永続化できないバグがあるためenv varで設定
export CLAUDE_CODE_EFFORT_LEVEL=max

#### Private overlay（存在する場合のみ読み込み） #####################

for f in "$HOME"/.zsh/private/*.zsh(N); do
  source "$f"
done
