#!/usr/bin/env bash
# Share context between Claude Code, Codex, and other tmux panes.

set -euo pipefail

orch_runtime_source="${BASH_SOURCE[0]}"
while [[ -L "$orch_runtime_source" ]]; do
  orch_runtime_dir="$(cd -P "$(dirname "$orch_runtime_source")" && pwd)"
  orch_runtime_target="$(readlink "$orch_runtime_source")"
  if [[ "$orch_runtime_target" != /* ]]; then
    orch_runtime_target="$orch_runtime_dir/$orch_runtime_target"
  fi
  orch_runtime_source="$orch_runtime_target"
done
orch_runtime_bin_dir="$(cd -P "$(dirname "$orch_runtime_source")" && pwd)"
ORCH_RUNTIME_LIB_DIR="${ORCH_RUNTIME_LIB_DIR:-$(cd "$orch_runtime_bin_dir/../lib/orch-runtime" && pwd)}"

# shellcheck source=../lib/orch-runtime/common.sh
source "$ORCH_RUNTIME_LIB_DIR/common.sh"
# shellcheck source=../lib/orch-runtime/metrics.sh
source "$ORCH_RUNTIME_LIB_DIR/metrics.sh"
# shellcheck source=../lib/orch-runtime/panes.sh
source "$ORCH_RUNTIME_LIB_DIR/panes.sh"
# shellcheck source=../lib/orch-runtime/commands.sh
source "$ORCH_RUNTIME_LIB_DIR/commands.sh"
# shellcheck source=../lib/orch-runtime/locks.sh
source "$ORCH_RUNTIME_LIB_DIR/locks.sh"
# shellcheck source=../lib/orch-runtime/report.sh
source "$ORCH_RUNTIME_LIB_DIR/report.sh"
# shellcheck source=../lib/orch-runtime/watch.sh
source "$ORCH_RUNTIME_LIB_DIR/watch.sh"
# shellcheck source=../lib/orch-runtime/workspace.sh
source "$ORCH_RUNTIME_LIB_DIR/workspace.sh"
# shellcheck source=../lib/orch-runtime/groups.sh
source "$ORCH_RUNTIME_LIB_DIR/groups.sh"
# shellcheck source=../lib/orch-runtime/main.sh
source "$ORCH_RUNTIME_LIB_DIR/main.sh"

main "$@"
